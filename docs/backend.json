
{
  "entities": {
    "Snippet": {
      "title": "Snippet",
      "description": "An HTML code snippet stored in the vault.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the snippet."
        },
        "title": {
          "type": "string",
          "description": "The title or description of the snippet."
        },
        "code": {
          "type": "string",
          "description": "The actual HTML code content."
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the snippet was created."
        }
      },
      "required": [
        "title",
        "code",
        "createdAt"
      ]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores basic information about a user.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        }
      },
      "required": [
        "uid",
        "email"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/users/{userId}/snippets/{snippetId}": {
      "schema": "Snippet",
      "description": "Private collection of snippets for a specific user."
    }
  }
}
